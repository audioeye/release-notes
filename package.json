{
  "name": "release-notes",
  "version": "1.0.3",
  "type": "module",
  "description": "Generate customer-facing release notes from GitHub releases",
  "scripts": {
    "generate": "tsx src/index.ts",
    "generate:clean": "rm -f data/releases.json && tsx src/index.ts",
    "clean": "rm -rf data/ output/",
    "serve": "npx serve ./output",
    "build": "tsc"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "marked": "^14.0.0",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
