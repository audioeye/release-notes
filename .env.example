# GitHub authentication — needs read:repo access for all listed repos
NPM_PACKAGE_READ_TOKEN=ghp_your_token_here

# Anthropic API key — used to rewrite change descriptions into customer-friendly notes (claude-opus-4-6)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# One or more GitHub repo URLs, comma-separated on a single line
# (dotenv drops unquoted newlines, so use commas or wrap in double-quotes)
# Append @branch to set a per-repo branch. Falls back to GITHUB_BRANCH or "main".
GITHUB_REPOS=https://github.com/audioeye/services-v2@staging,https://github.com/audioeye/a11y-testing@main

# Default branch for any repo without an explicit @branch suffix (default: main)
# GITHUB_BRANCH=main

# Site metadata (used in the HTML page and RSS feed)
SITE_TITLE=Platform Release Notes
SITE_DESCRIPTION=Latest updates and improvements to the AudioEye platform
SITE_BASE_URL=https://releases.audioeye.com

# Output paths (optional, defaults shown)
# OUTPUT_DIR=./output
# DATA_DIR=./data
